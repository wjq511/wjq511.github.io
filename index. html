<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>VOLT-X 电光概念超跑</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft YaHei", "PingFang SC", sans-serif;
        }
        body {
            background-color: #ffffff;
            display: flex;
            justify-content: center;
            padding: 20px 0;
        }
        /* 手机容器 严格匹配原图尺寸 宽960px 高2191px */
        .mobile-frame {
            width: 960px;
            height: 2191px;
            overflow: hidden;
            background: linear-gradient(180deg, #040720 0%, #332c62 100%);
            color: #b7edf7;
            position: relative;
        }
        /* ========== 全局电光霓虹动画关键帧 ========== */
        /* 文字呼吸发光 */
        @keyframes neon-breath {
            0% {
                text-shadow: 0 0 6px #42e1f1, 0 0 12px #20b9d9;
                opacity: 0.85;
            }
            50% {
                text-shadow: 0 0 14px #42e1f1, 0 0 28px #20b9d9, 0 0 42px #00ccff;
                opacity: 1;
            }
            100% {
                text-shadow: 0 0 6px #42e1f1, 0 0 12px #20b9d9;
                opacity: 0.85;
            }
        }
        /* 标签流光闪烁 */
        @keyframes tag-shine {
            0% {
                background-color: rgba(66, 225, 241, 0.12);
                box-shadow: 0 0 0px transparent;
            }
            50% {
                background-color: rgba(66, 225, 241, 0.32);
                box-shadow: 0 0 18px #42e1f1;
            }
            100% {
                background-color: rgba(66, 225, 241, 0.12);
                box-shadow: 0 0 0px transparent;
            }
        }
        /* 图片电光明暗流动 */
        @keyframes flash-light-wave {
            0% { filter: brightness(1); }
            50% { filter: brightness(1.16); }
            100% { filter: brightness(1); }
        }
        /* 顶部导航栏 */
        .top-nav-bar {
            width: 100%;
            height: 82px;
            background-color: rgba(0, 0, 0, 0.72);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 42px;
        }
        .nav-left-group {
            display: flex;
            align-items: center;
            gap: 22px;
        }
        .nav-logo-icon {
            width: 50px;
            height: 34px;
            background-color: #ffc946;
            border-radius: 4px;
        }
        .nav-text-item {
            font-size: 30px;
            color: #b7edf7;
        }
        .nav-text-item.active {
            color: #42e1f1;
            animation: neon-breath 3s infinite ease-in-out;
        }
        /* 头部标题区域 */
        .banner-title-area {
            text-align: center;
            padding: 44px 22px 22px;
        }
        .main-page-title {
            font-size: 66px;
            color: #42e1f1;
            letter-spacing: 5px;
            animation: neon-breath 3.2s infinite ease-in-out;
            position: relative;
        }
        .main-page-title::after {
            content: "VOLT-X 电光概念超跑";
            position: absolute;
            left: 0;
            right: 0;
            top: 12px;
            opacity: 0.18;
            filter: blur(5px);
        }
        .page-slogan {
            font-size: 33px;
            margin-top: 26px;
            color: #c1e9f3;
            animation: neon-breath 4s infinite ease-in-out;
        }
        /* 主视觉整车大图 */
        .main-car-banner {
            width: 100%;
            height: 630px;
            background-color: #0f0f22;
            background-image: url("banner-full-car.jpg");
            background-size: cover;
            background-position: center;
            animation: flash-light-wave 4.2s infinite ease-in-out;
        }
        /* 左右切换按钮栏 */
        .switch-operation-bar {
            display: flex;
            justify-content: space-between;
            padding: 26px 22px;
            font-size: 35px;
        }
        .switch-left-btn, .switch-right-btn {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .arrow-icon {
            font-size: 42px;
            color: #42e1f1;
            animation: neon-breath 2.6s infinite ease-in-out;
        }
        /* 前脸车尾双栏模块容器 */
        .two-column-car-part {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 22px;
            padding: 0 22px 42px;
        }
        .single-part-card {
            background-color: rgba(42, 36, 92, 0.52);
            border-radius: 14px;
            padding: 22px;
        }
        .card-top-desc {
            font-size: 27px;
            margin-bottom: 18px;
            opacity: 0.92;
        }
        .module-tag-label {
            font-size: 33px;
            padding: 7px 18px;
            border-radius: 32px;
            display: inline-block;
            margin-bottom: 22px;
            color: #42e1f1;
            animation: tag-shine 3.6s infinite ease-in-out;
        }
        .card-image-box {
            width: 100%;
            height: 326px;
            border-radius: 10px;
            margin-bottom: 22px;
            background-color: #090921;
            animation: flash-light-wave 4.2s infinite ease-in-out;
        }
        .feature-list {
            list-style: none;
        }
        .feature-list li {
            font-size: 29px;
            line-height: 1.82;
            position: relative;
            padding-left: 26px;
        }
        .feature-list li::before {
            content: "•";
            color: #42e1f1;
            position: absolute;
            left: 0;
            animation: neon-breath 2.2s infinite ease-in-out;
        }
        /* 通用配件模块（轮毂/尾翼） */
        .accessory-module {
            padding: 42px 22px;
            border-top: 1px solid rgba(66, 225, 241, 0.22);
        }
        .module-title-center {
            text-align: center;
            margin-bottom: 32px;
        }
        .three-col-content {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            align-items: center;
            gap: 22px;
        }
        .col-text-desc {
            font-size: 33px;
            line-height: 1.62;
            text-align: center;
            animation: neon-breath 4.6s infinite ease-in-out;
        }
        .col-image-box {
            width: 100%;
            height: 286px;
            border-radius: 10px;
            background-color: #000000;
            animation: flash-light-wave 4.2s infinite ease-in-out;
        }
        /* 尾翼模块底部留白 */
        .spoiler-module-bottom {
            padding-bottom: 124px;
        }
        /* 底部全局导航栏 */
        .bottom-tab-nav {
            width: 100%;
            height: 92px;
            background-color: #000000;
            position: absolute;
            bottom: 0;
            left: 0;
            display: flex;
            justify-content: space-around;
            align-items: center;
        }
        .tab-icon-box {
            width: 52px;
            height: 52px;
            border: 3px solid #42e1f1;
            border-radius: 6px;
            animation: neon-breath 3s infinite ease-in-out;
        }
    </style>
</head>
<body>
    <div class="mobile-frame">
        <!-- 顶部导航栏 -->
        <div class="top-nav-bar">
            <div class="nav-left-group">
                <div class="nav-logo-icon"></div>
                <span class="nav-text-item">首页</span>
            </div>
            <span class="nav-text-item active">车型介绍</span>
            <span class="nav-text-item">核心黑科技</span>
        </div>

        <!-- 页面主标题 -->
        <div class="banner-title-area">
            <h1 class="main-page-title">VOLT-X 电光概念超跑</h1>
            <p class="page-slogan">以电光重塑陆地极限，纯电超跑未来形态</p>
        </div>

        <!-- 全屏整车主视觉图 -->
        <div class="main-car-banner"></div>

        <!-- 左右切换操作栏 -->
        <div class="switch-operation-bar">
            <div class="switch-left-btn">
                <span class="arrow-icon">◀</span>
                <span>立即预约试驾</span>
            </div>
            <div class="switch-right-btn">
                <span>探索车型详情</span>
                <span class="arrow-icon">▶</span>
            </div>
        </div>

        <!-- 前脸+车尾双栏区域 -->
        <div class="two-column-car-part">
            <!-- 左侧：锋芒电光前脸 -->
            <div class="single-part-card">
                <p class="card-top-desc">VOLT-X 电光纯电超跑 · 正面锋芒登场</p>
                <div class="card-image-box" style="background-image:url('car-front.jpg');background-size:cover;background-position:center;"></div>
                <span class="module-tag-label">锋芒电光前脸</span>
                <ul class="feature-list">
                    <li>0.19超低风阻前脸</li>
                    <li>可编程电光流水灯光</li>
                    <li>自适应矩阵刀锋大灯</li>
                    <li>碳纤维分流前铲</li>
                    <li>全景透明透视座舱</li>
                </ul>
            </div>
            <!-- 右侧：流光竞速车尾 -->
            <div class="single-part-card">
                <span class="module-tag-label">流光竞速车尾</span>
                <ul class="feature-list">
                    <li>竞技碳纤维高尾翼</li>
                    <li>可编程贯穿流光尾灯</li>
                    <li>五层风道导流扩散器</li>
                    <li>溜背流体曲面车尾</li>
                    <li>可视化电能电光特效</li>
                </ul>
                <div class="card-image-box" style="background-image:url('car-rear.jpg');background-size:cover;background-position:center;"></div>
            </div>
        </div>

        <!-- 冷光环轮 锻造多辐 轮毂模块 -->
        <div class="accessory-module">
            <div class="module-title-center">
                <span class="module-tag-label">冷光环轮 | 锻造多辐</span>
            </div>
            <div class="three-col-content">
                <div class="col-text-desc">
                    炭黑哑光基底<br>
                    静止即是赛道<br>
                    性能与科幻
                </div>
                <div class="col-image-box" style="background-image:url('car-wheel.jpg');background-size:cover;background-position:center;"></div>
                <div class="col-text-desc">
                    蓝光环绕轮辋<br>
                    转动自带流光<br>
                    一轮兼得
                </div>
            </div>
        </div>

        <!-- 光刃尾翼 流线银躯 尾翼模块 -->
        <div class="accessory-module spoiler-module-bottom">
            <div class="module-title-center">
                <span class="module-tag-label">光刃尾翼 | 流线银躯</span>
            </div>
            <div class="three-col-content">
                <div class="col-text-desc">
                    冰蓝霓虹勾勒<br>
                    静藏竞速锋芒<br>
                    速度与未来
                </div>
                <div class="col-image-box" style="background-image:url('car-spoiler.jpg');background-size:cover;background-position:center;"></div>
                <div class="col-text-desc">
                    空气动力学曲面<br>
                    动驭疾风之势<br>
                    一翼尽显
                </div>
            </div>
        </div>

        <!-- 底部功能导航栏 -->
        <div class="bottom-tab-nav">
            <div class="tab-icon-box"></div>
            <div class="tab-icon-box"></div>
            <div class="tab-icon-box"></div>
            <div class="tab-icon-box"></div>
        </div>
    </div>

    <script>
        // 顶部左右切换按钮交互
        const leftSwitchBtn = document.querySelector('.switch-left-btn');
        const rightSwitchBtn = document.querySelector('.switch-right-btn');
        leftSwitchBtn.addEventListener('click', function() {
            alert('跳转预约试驾页面');
        });
        rightSwitchBtn.addEventListener('click', function() {
            alert('滑动查看车型完整详情');
        });

        // 底部四个导航图标点击交互
        const bottomIcons = document.querySelectorAll('.tab-icon-box');
        const iconTips = ['车型手册', '电话咨询', '车型目录', '展厅实景'];
        bottomIcons.forEach((iconDom, index) => {
            iconDom.addEventListener('click', function() {
                alert('点击功能：' + iconTips[index]);
            });
        });
    </script>
</body>
</html>